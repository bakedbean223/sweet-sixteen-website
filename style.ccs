body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #0f0f0f;
  color: white;
  text-align: center;
}

.container {
  padding: 30px;
}

h1 {
  font-size: 2.5rem;
}

.date, .dress {
  opacity: 0.8;
}

.card {
  background: #1c1c1c;
  margin: 20px auto;
  padding: 20px;
  border-radius: 15px;
  max-width: 400px;
}
